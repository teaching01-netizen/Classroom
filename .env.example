# Railway auto-injects (when using Railway Postgres plugin):
#   PORT
#   DATABASE_URL
# If NOT using Railway Postgres, set DATABASE_URL manually:
# DATABASE_URL=postgres://user:pass@host:5432/db

# Must add in Railway dashboard:
WARWICK_EMAIL=
WARWICK_PASSWORD=
# Cache warmer: how often to refresh Warwick course data in background
# Default: 30s
WARWICK_CACHE_INTERVAL=30s

# Session pool sizing per traffic tier
# WARWICK_QR_SESSIONS: number of QR polling sessions (default: 2)
WARWICK_QR_SESSIONS=2
# WARWICK_TEACHER_SESSIONS: number of teacher/toggle sessions (default: 2)
WARWICK_TEACHER_SESSIONS=2
# WARWICK_INTERACTIVE_SESSIONS: number of interactive check-in sessions (default: 2)
WARWICK_INTERACTIVE_SESSIONS=2

# Shared HTTP transport — limits per-host connections
# WARWICK_CONNS_PER_HOST: max concurrent connections per host (default: 50)
WARWICK_CONNS_PER_HOST=50

# Max concurrent WebSocket connections (default: 500)
WARWICK_MAX_CONCURRENT_WS=500

# Optional (same-origin in Railway — no CORS needed):
# CORS_ORIGIN=https://your-custom-domain.com
# Optional (defaults to relative /ws — auto-detects origin):
# VITE_WS_URL=wss://your-app.railway.app/ws

# Railway auto-injects (when using Railway Postgres plugin):
#   PORT
#   DATABASE_URL
# If NOT using Railway Postgres, set DATABASE_URL manually:
# DATABASE_URL=postgres://user:pass@host:5432/db

# Must add in Railway dashboard:
WARWICK_EMAIL=
WARWICK_PASSWORD=
# Cache warmer: how often to refresh Warwick course data in background
# Default: 30s
WARWICK_CACHE_INTERVAL=30s

# Optional (same-origin in Railway — no CORS needed):
# CORS_ORIGIN=https://your-custom-domain.com
# Optional (defaults to relative /ws — auto-detects origin):
# VITE_WS_URL=wss://your-app.railway.app/ws
